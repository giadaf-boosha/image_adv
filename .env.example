# LLM primario (Google Gemini)
GOOGLE_API_KEY=your_google_api_key_here
PRIMARY_MODEL=gemini-3.1-flash-image-preview

# LLM fallback (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
FALLBACK_MODEL=gpt-4o

# Dati locali
TAXONOMY_PATH=data/taxonomy.json
QUALITY_CRITERIA_PATH=data/quality_criteria.json
ALERTS_LOG_PATH=data/new_type_alerts_log.jsonl

# Soglie pipeline
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.45
NOVELTY_TRIGGER_THRESHOLD=0.45

# Timeout LLM (secondi)
LLM_TIMEOUT_SECONDS=45

# Versione applicazione
APP_VERSION=1.0.0
